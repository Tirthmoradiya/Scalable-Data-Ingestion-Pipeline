# ── Application ─────────────────────────────────────────────────────────────
ENVIRONMENT=development
APP_NAME=data-pipeline

# ── Database (MySQL) ─────────────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_NAME=data_pipeline
DB_USER=root
DB_PASSWORD=secret
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20
DB_POOL_RECYCLE=1800
DB_ECHO=false

# ── Pipeline ─────────────────────────────────────────────────────────────────
PIPELINE_BATCH_SIZE=500
PIPELINE_MAX_WORKERS=4
PIPELINE_CHUNK_SIZE=1000
PIPELINE_DEAD_LETTER_DIR=dead_letter
PIPELINE_RETRY_MAX_ATTEMPTS=3
PIPELINE_RETRY_BACKOFF_FACTOR=0.5

# ── Observability ─────────────────────────────────────────────────────────────
OBS_LOG_LEVEL=INFO
OBS_LOG_FORMAT=console
OBS_METRICS_ENABLED=true
OBS_METRICS_PORT=9090
OBS_TRACING_ENABLED=false

# ── FastAPI ───────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
